# Modelbox — variables de entorno. Copiá este archivo a `.env` y completá.
#
#   cp .env.example .env
#
# docker-compose lee `.env` automáticamente. (.env está en .gitignore: tus
# secretos reales nunca se commitean.) Sin Docker, exportá estas variables en tu
# shell antes de correr `python server.py`.

# --- Modelos incluidos en la imagen (build arg) ---
# Combinación de: supertonic,pocket,qwen,whisper
# Solo se instalan las librerías de los que listes (imagen más liviana).
MODELS=supertonic,pocket,qwen,whisper

# --- Seguridad (opcional) ---
# Sin nada de esto: el panel queda abierto y la API apagada.
# Login del panel (ambos deben estar para activar el login):
PANEL_USER=
PANEL_PASSWORD=
# Token de la API (header: Authorization: Bearer <token>).
# Sin esto, la API queda DESACTIVADA (503). Poné un valor largo y aleatorio.
API_TOKEN=

# --- Operativo (opcional; estos son los valores por defecto) ---
# Inferencias en paralelo. En CPU, 1 ya usa todos los cores; el resto va a cola.
MODELBOX_MAX_CONCURRENT=1
# Tamaño de Whisper: small / medium / large-v3 (small int8 ~ 1 GB RAM).
MODELBOX_WHISPER_SIZE=small
# Tope de tamaño (MB) para audios subidos a /api/clone y /api/transcribe.
MODELBOX_MAX_UPLOAD_MB=25
