# Modelbox — variables de entorno. Copiar este archivo a `.env` y completar.
#
#   cp .env.example .env
#
# docker-compose lee `.env` automáticamente. (.env está en .gitignore: los
# secretos reales no se commitean.) Sin Docker, exportar estas variables en el
# shell antes de ejecutar `python server.py`.

# --- Modelos incluidos en la imagen (build arg) ---
# Combinación de: supertonic,pocket,qwen,whisper
# Solo se instalan las librerías de los modelos listados (imagen más liviana).
MODELS=supertonic,pocket,qwen,whisper

# --- Seguridad (opcional) ---
# Sin nada de esto: el panel queda abierto y la API apagada.
# Login del panel (ambos deben estar definidos para activar el login):
PANEL_USER=
PANEL_PASSWORD=
# Token de la API (header: Authorization: Bearer <token>).
# Sin esto, la API queda DESACTIVADA (503). Usar un valor largo y aleatorio.
API_TOKEN=

# Opcional: token de Hugging Face para descargar pesos gated de Pocket-TTS
# (aceptar antes los terminos en https://huggingface.co/kyutai/pocket-tts).
HF_TOKEN=

# --- Operativo (opcional; estos son los valores por defecto) ---
# Directorio persistente unico dentro del contenedor. Compose/Dokploy usan /modelbox-data.
# En desarrollo local conviene dejarlo vacio para usar las rutas del repo.
# MODELBOX_DATA_DIR=/modelbox-data
# Inferencias en paralelo. En CPU, 1 ya usa todos los cores; el resto va a cola.
MODELBOX_MAX_CONCURRENT=1
# Tope de caracteres para /api/tts y TTS preset del panel.
MODELBOX_MAX_TTS_CHARS=2000
# Tope de caracteres para /api/clone y clonacion del panel.
MODELBOX_MAX_CLONE_CHARS=2000
# Tope de duracion para audios subidos a clone/transcribe.
MODELBOX_MAX_AUDIO_SECONDS=1200
# Tamano de Whisper: small / medium / large-v3 (small int8 ~ 1 GB RAM).
MODELBOX_WHISPER_SIZE=small
# Tope de tamano (MB) para audios subidos a /api/clone y /api/transcribe.
MODELBOX_MAX_UPLOAD_MB=30
